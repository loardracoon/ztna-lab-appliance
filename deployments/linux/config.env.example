# /etc/ztna-lab/config.env
#
# Configuração do appliance no modo bare metal.
# Cada linha é lida pelo systemd e exportada como variável de ambiente.
# Edite e reinicie com:   sudo systemctl restart ztna-lab

# ─── paths persistentes ─────────────────────────────────────────────
# StateDirectory= e LogsDirectory= no .service já criam /var/lib/ztna-lab
# e /var/log/ztna-lab com as permissões corretas.
ZTNA_DNS_RECORDS=/var/lib/ztna-lab/dns_records.json
ZTNA_SSH_KEY=/var/lib/ztna-lab/ssh_host_key
ZTNA_LOG_PATH=/var/log/ztna-lab/ztna_lab.log
ZTNA_HISTORY_FILE=/var/lib/ztna-lab/ztna_lab.history

# ─── plano de admin ─────────────────────────────────────────────────
# Bind. Use 127.0.0.1:9000 se um reverse proxy (nginx, Traefik) for terminar TLS
# e expor a UI publicamente. Use 0.0.0.0:9000 só em rede de laboratório fechada.
ZTNA_ADMIN_ADDR=0.0.0.0:9000

# Bearer token. Vazio = sem autenticação (apenas para lab isolado).
# Gere com:  openssl rand -hex 32
#ZTNA_ADMIN_TOKEN=

# ─── auto-start dos servidores no boot ──────────────────────────────
ZTNA_AUTOSTART_DNS=true
ZTNA_AUTOSTART_HTTP=true
ZTNA_AUTOSTART_SSH=true
